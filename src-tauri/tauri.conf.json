{
  "productName": "Recall",
  "version": "0.0.1-beta",
  "identifier": "com.recall.app",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": ["PortugueseBR", "English"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Recall",
        "width": 1100,
        "height": 900,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "plugins": {}
}
